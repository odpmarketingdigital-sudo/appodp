// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/app/generated/prisma"
}

// URL resolvida via prisma.config.ts (Prisma 7) — sem url inline aqui
datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

/// Papel do usuário dentro de uma empresa
enum CompanyRole {
  OWNER
  ADMIN
  MEMBER
}

/// Provedores de marketing suportados para integração
enum IntegrationProvider {
  GA4
  GOOGLE_ADS
  META_ADS
  RD_STATION
  ACTIVECAMPAIGN
}

// ─────────────────────────────────────────────
// Auth.js v5 — models do Prisma Adapter oficial
// ─────────────────────────────────────────────

/// Usuários autenticados pelo Auth.js
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  /// Hash bcrypt para login por e-mail/senha (null = apenas OAuth ou convite pendente)
  passwordHash  String?   @map("password_hash")
  /// Administrador global do sistema (God Mode)
  isSystemAdmin Boolean   @default(false) @map("is_system_admin")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts    Account[]
  sessions    Session[]
  memberships CompanyMember[]

  @@map("users")
}

/// Token temporário para redefinição de senha
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("password_reset_tokens")
}

/// Contas OAuth vinculadas ao usuário (ex.: Google)
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

/// Sessões persistidas no banco (Auth.js + Prisma Adapter)
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

/// Tokens de verificação exigidos pelo Auth.js
model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// Domínio — multi-tenant (User ↔ Company ↔ Client)
// ─────────────────────────────────────────────

/// Empresas (agências)
model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members      CompanyMember[]
  clients      Client[]
  subscription Subscription?

  @@map("companies")
}

/// Assinatura (Stripe) vinculada a uma empresa — 1 para 1
model Subscription {
  id                   String    @id @default(cuid())
  companyId            String    @unique @map("company_id")
  stripeCustomerId     String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  stripePriceId        String?   @map("stripe_price_id")
  /// Status da assinatura: free, active, past_due, canceled, etc.
  status               String    @default("free")
  currentPeriodEnd     DateTime? @map("current_period_end")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

/// Vínculo entre usuário e empresa, com papel (role) por membership
model CompanyMember {
  id        String      @id @default(cuid())
  role      CompanyRole @default(MEMBER)
  userId    String      @map("user_id")
  companyId String      @map("company_id")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@map("company_members")
}

/// Clientes pertencentes a uma empresa
model Client {
  id            String   @id @default(cuid())
  name          String
  email         String?
  /// Propriedade GA4 monitorada neste cliente (ex.: "123456789")
  ga4PropertyId String?  @map("ga4_property_id")
  isActive      Boolean  @default(true) @map("is_active")
  companyId     String   @map("company_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company           Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  integrationTokens IntegrationToken[]
  marketingMetrics  MarketingMetricHistory[]

  @@index([companyId])
  @@map("clients")
}

/// Tokens/credenciais de integração de marketing vinculados a um cliente
model IntegrationToken {
  id                String              @id @default(cuid())
  provider          IntegrationProvider
  clientId          String              @map("client_id")
  accessToken       String              @map("access_token") @db.Text
  refreshToken      String?             @map("refresh_token") @db.Text
  expiresAt         DateTime?           @map("expires_at")
  scope             String?
  externalAccountId String?             @map("external_account_id")
  isActive          Boolean             @default(true) @map("is_active")
  metadata          Json?
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, provider])
  @@index([clientId])
  @@map("integration_tokens")
}

/// Histórico diário de métricas de marketing coletadas dos provedores
model MarketingMetricHistory {
  id          String              @id @default(cuid())
  clientId    String              @map("client_id")
  provider    IntegrationProvider
  /// Dia de referência das métricas (00:00 UTC)
  date        DateTime            @db.Date
  impressions Int                 @default(0)
  clicks      Int                 @default(0)
  cost        Float               @default(0)
  conversions Int                 @default(0)
  revenue     Float               @default(0)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, provider, date])
  @@index([clientId, provider])
  @@map("marketing_metric_history")
}

